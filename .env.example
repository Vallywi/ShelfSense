# ─── ShelfSense environment variables ──────────────────────────────
# Copy this file to `.env` and fill in your real values.
# `.env` itself is gitignored — never commit secrets.

# Google Gemini API key (required for Chef Sage AI + Expiry Date scanning)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# JWT signing secret (used to sign user auth tokens)
# Generate a long random string. Anything 32+ chars is fine.
JWT_SECRET=replace-with-a-long-random-string

# ─── Optional: Vercel KV for persistent storage ────────────────────
# Leave blank for local in-memory dev (data resets on server restart).
KV_REST_API_URL=
KV_REST_API_TOKEN=
